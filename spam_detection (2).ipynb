    {
      "cell_type": "code",
      "source": [
        "def remove_StepWords(text):\n",
        "  stop_words=set(stopwords.words('english'))\n",
        "  for tokens in text:\n",
        "    if tokens in stop_words:\n",
        "      text.remove(tokens)\n",
        "  return text\n",
        "df['clean_message']=df['clean_message'].apply(lambda x : remove_StepWords(x))\n",
        "df.head()"
      ],
