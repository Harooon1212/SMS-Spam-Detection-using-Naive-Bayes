      "source": [
        "def remove_punctuations(text):\n",
        "  punc=string.punctuation\n",
        "  text=text.translate(str.maketrans('','',punc))\n",
        "  return text\n",
        "df['clean_message']=df['clean_message'].apply(lambda x : remove_punctuations(x))\n",
        "df.head()"
      ],
